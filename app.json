{
  "expo": {
    "name": "Titra Health",
    "slug": "titra-health",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "titrahealth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.titrahealth.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSHealthShareUsageDescription": "TitraHealth reads your health data to personalize your GLP-1 experience.",
        "NSHealthUpdateUsageDescription": "TitraHealth writes step and activity data to Apple Health.",
        "NSMicrophoneUsageDescription": "TitraHealth uses your microphone to log food, activity, and health entries by voice.",
        "NSUserNotificationsUsageDescription": "TitraHealth sends reminders to help you stay on track with logging.",
        "NSCameraUsageDescription": "TitraHealth uses your camera to photograph food for nutritional analysis.",
        "NSPhotoLibraryUsageDescription": "TitraHealth accesses your photo library to select food images for nutritional analysis.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.Sign-in-with-Apple": "Default"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_BLOOD_GLUCOSE",
        "android.permission.health.READ_NUTRITION",
        "android.permission.health.READ_BODY_WEIGHT",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.WRITE_NUTRITION",
        "android.permission.health.WRITE_BODY_WEIGHT",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "TitraHealth reads your health data to personalize your GLP-1 experience.",
          "NSHealthUpdateUsageDescription": "TitraHealth writes step and activity data to Apple Health."
        }
      ],
      "react-native-health-connect",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF742A",
          "sounds": []
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "TitraHealth uses your camera to photograph food for nutritional analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TitraHealth accesses your photo library to select food images for nutritional analysis.",
          "cameraPermission": "TitraHealth uses your camera to photograph food for nutritional analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "976538a1-cd7e-45ef-bea0-97e59e88fc27"
      }
    },
    "owner": "ibm7862"
  }
}
